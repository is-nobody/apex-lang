{
  "name": "Apex",
  "scopeName": "source.apex",
  "fileTypes": [
    "apex"
  ],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#library-call" },
    { "include": "#variable" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.apex",
          "match": "//.*$"
        },
        {
          "name": "comment.line.shebang.apex",
          "match": "^#!.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.apex",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.apex",
              "match": "\\\\."
            },
            {
              "name": "constant.character.interpolation.apex",
              "match": "\\{[a-zA-Z_][a-zA-Z0-9_\\s\\+\\-\\*\\/]*\\}"
            }
          ]
        },
        {
          "name": "string.quoted.single.apex",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.apex",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.apex",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.apex",
          "match": "\\b(function|if|elif|else|for|break|continue|return|import|and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.apex",
          "match": "\\b(true|false|none)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.apex",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.apex",
          "match": "\\+|\\-|\\*|\\/|%"
        },
        {
          "name": "keyword.operator.assignment.apex",
          "match": "="
        }
      ]
    },
    "function-def": {
      "patterns": [
        {
          "name": "meta.function.apex",
          "begin": "\\b(function)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "end": "(?=\\n|$|//)",
          "beginCaptures": {
            "1": { "name": "keyword.control.apex" },
            "2": { "name": "entity.name.function.apex" }
          },
          "patterns": [
            { "include": "#function-params" }
          ]
        }
      ]
    },
    "function-params": {
      "patterns": [
        {
          "name": "variable.parameter.apex",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.apex",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.apex" }
          }
        }
      ]
    },
    "library-call": {
      "patterns": [
        {
          "name": "support.function.library.apex",
          "match": "\\b(os|sys|math|string|table|ffi|random|codecs)\\s*\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "support.class.apex" },
            "2": { "name": "support.function.apex" }
          }
        }
      ]
    },
    "variable": {
      "patterns": [
        {
          "name": "variable.other.apex",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b"
        }
      ]
    }
  }
}