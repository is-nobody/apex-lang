{
  "name": "apex-language-support",
  "displayName": "Apex Language Support 26.06",
  "description": "Syntax highlighting and language support for the Apex programming language",
  "version": "26.6.0",
  "publisher": "apex-lang",
  "engines": {
    "vscode": "^1.60.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/is-nobody/apex-lang"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:apex"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "apex",
        "aliases": [
          "Apex",
          "apex"
        ],
        "extensions": [
          ".apex"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "apex",
        "scopeName": "source.apex",
        "path": "./syntaxes/apex.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "apex.runFile",
        "title": "Apex: Run Current File"
      }
    ],
    "keybindings": [
      {
        "command": "apex.runFile",
        "key": "ctrl+shift+r",
        "when": "editorLangId == apex"
      }
    ],
    "snippets": [
      {
        "language": "apex",
        "path": "./snippets.json"
      }
    ]
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0"
  }
}