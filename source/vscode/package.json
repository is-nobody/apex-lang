{
  "name": "apex-language",
  "displayName": "Apex",
  "description": "Language support for the Apex programming language",
  "version": "26.0.6",
  "publisher": "apex-lang",
  "engines": {
    "vscode": "^1.60.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/is-nobody/apex-lang"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:apex"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "apex",
        "aliases": [
          "Apex",
          "apex"
        ],
        "extensions": [
          ".apex"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "apex",
        "scopeName": "source.apex",
        "path": "./syntaxes/apex.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "apex.runFile",
        "title": "Apex: Run Current File",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "apex.runFile",
          "group": "navigation",
          "when": "editorLangId == apex"
        }
      ]
    },
    "keybindings": [
      {
        "command": "apex.runFile",
        "key": "f5",
        "when": "editorLangId == apex"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2"
  }
}