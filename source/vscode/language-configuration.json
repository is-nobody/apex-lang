{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(function|if|elif|else|for|while)\\b.*$",
    "decreaseIndentPattern": "^\\s*(elif|else|end)?\\s*$"
  }
}